  CANCELLED
}

enum ProductivityReviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum ProductivityReviewType {
  HIRING
  BRANCH_TRANSFER
  OFFBOARDING
}

enum OperationalEventType {
  HIRING_INITIATED
  BRANCH_TRANSFER_INITIATED
  OFFBOARDING_INITIATED
  CANDIDACY_COMPLETED
  HIRING_COMPLETED
  ONBOARDING_COMPLETED
  TRAINING_COMPLETED
  OPERATION_CONFIRMED
  COMPLIANCE_COMPLETED
  SIGNATURE_COMPLETED
  ASSET_ASSIGNED
  TRAINING_ACTIVATED
  ACCESS_PROVISIONED
  ASSET_RECOVERED
  ACCESS_CLOSED
  RECORD_ARCHIVED
  PRODUCTIVITY_REVIEW_CREATED
  WORKFLOW_STEP_STARTED
  WORKFLOW_STEP_COMPLETED
  WORKFLOW_NOTE_ADDED
  WORKFLOW_BLOCKER_CREATED
  WORKFLOW_BLOCKER_RESOLVED
  MASTER_WORKFLOW_RECOMPUTED
}

model Tenant {
  id                          String                       @id @default(uuid())
  name                        String
  slug                        String                       @unique
  status                      TenantStatus                 @default(ACTIVE)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  users                       User[]
  roles                       Role[]
  subscription                Subscription?
  auditLogs                   AuditLog[]
  candidates                  Candidate[]
  branches                    Branch[]
  employees                   Employee[]
  employeeBranches            EmployeeBranch[]
  vacancies                   Vacancy[]
  vacancyFormTemplates        VacancyFormTemplate[]
  applications                VacancyApplication[]
  inventoryItems              InventoryItem[]
  inventoryStocks             InventoryStock[]
  trainingModuleAccesses      TenantTrainingModuleAccess[]
  trainingCategories          TrainingCategory[]
  trainingCurriculums         TrainingCurriculum[]
  trainingCourses             TrainingCourse[]
  trainingAssignments         TrainingAssignment[]
  trainingProgressRecords     TrainingProgress[]
  trainingStepProgressRecords TrainingStepProgress[]
  trainingEvents              TrainingEvent[]
  trainingLibraryResources    TrainingLibraryResource[]
  trainingQuizAttempts        TrainingQuizAttempt[]
  trainingCertificates        TrainingCertificate[]
  trainingFavorites           TrainingFavorite[]
  trainingAnalyticsSnapshots  TrainingAnalyticsSnapshot[]
  featureFlags                TenantFeatureFlag[]
  notifications               Notification[]
  billingCustomer             BillingCustomer?
  billingInvoices             BillingInvoice[]
  userSessions                UserSession[]
  masterWorkflows             MasterWorkflow[]
  workflowSteps               WorkflowStep[]
  hiringFlows                 HiringFlow[]
  onboardingFlows             OnboardingFlow[]
  onboardingTasks             OnboardingTask[]
  signaturePackages           SignaturePackage[]
  signatureParticipants       SignatureParticipant[]
  inventoryAssignments        InventoryAssignment[]
  inventoryRecoveries         InventoryRecovery[]
  workflowTrainingAssignments WorkflowTrainingAssignment[]
  accessTasks                 AccessTask[]
  productivityReviews         ProductivityReview[]
  operationalEvents           OperationalEvent[]
  workflowBlockers            WorkflowBlocker[]
  automationRules             AutomationRule[]
  automationExecutions        AutomationExecution[]
  automationExecutionSteps    AutomationExecutionStep[]
  automationAuditLogs         AutomationAuditLog[]
  policyChecks                PolicyCheck[]
  assetAssignments            AssetAssignment[]
  trainingActivations         TrainingActivation[]
}

model User {
  id                          String                      @id @default(uuid())
  tenantId                    String
  activeBranchId              String?
  email                       String
  passwordHash                String
  firstName                   String
  lastName                    String
  status                      UserStatus                  @default(ACTIVE)
  isSuperAdmin                Boolean                     @default(false)
  refreshTokenHash            String?
  lastLoginAt                 DateTime?
  lastSeenAt                  DateTime?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  activeBranch                Branch?                     @relation("UserActiveBranch", fields: [activeBranchId], references: [id], onDelete: SetNull)
  userRoles                   UserRole[]
  userPermissions             UserPermission[]
  auditLogs                   AuditLog[]
  branchAccesses              UserBranchAccess[]
  createdVacancies            Vacancy[]                   @relation("VacancyCreatedBy")
  assignedTrainingAssignments TrainingAssignment[]        @relation("TrainingAssignmentsUser")
  createdTrainingAssignments  TrainingAssignment[]        @relation("TrainingAssignmentsAssignedBy")
  trainingProgressRecords     TrainingProgress[]
  trainingStepProgressRecords TrainingStepProgress[]
  trainingEventAttendances    TrainingEventAttendance[]
  trainingQuizAttempts        TrainingQuizAttempt[]
  trainingCertificates        TrainingCertificate[]
  trainingFavorites           TrainingFavorite[]
  trainingAnalyticsSnapshots  TrainingAnalyticsSnapshot[]
  notifications               Notification[]
  sessions                    UserSession[]
  triggeredWorkflows          MasterWorkflow[]            @relation("WorkflowTriggeredBy")
  operationalEvents           OperationalEvent[]          @relation("OperationalEventActor")
  productivityReviews         ProductivityReview[]        @relation("ProductivityReviewActor")
  createdAutomationRules      AutomationRule[]            @relation("AutomationRuleCreatedBy")
  automationExecutions        AutomationExecution[]       @relation("AutomationExecutionActor")
  automationAuditLogs         AutomationAuditLog[]        @relation("AutomationAuditActor")
  policyChecks                PolicyCheck[]               @relation("PolicyCheckCreatedBy")

  @@unique([tenantId, email])
  @@index([activeBranchId])
  @@index([tenantId])
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String
  code            String
  name            String
  description     String?
  scope           AccessScope      @default(TENANT)
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model Plan {
  id                           String                       @id @default(uuid())
  code                         PlanCode                     @unique
  name                         String
  description                  String?
  priceMonthly                 Decimal?                     @db.Decimal(10, 2)
  priceYearly                  Decimal?                     @db.Decimal(10, 2)
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  subscriptions                Subscription[]
  planModules                  PlanModule[]
  tenantTrainingModuleAccesses TenantTrainingModuleAccess[]
}

model FeatureModule {
  id          String       @id @default(uuid())
  code        ModuleCode   @unique
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  planModules PlanModule[]
}

model PlanModule {
  planId    String
  moduleId  String
  enabledAt DateTime      @default(now())
  plan      Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  module    FeatureModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([planId, moduleId])
}

model Subscription {
  id                     String                       @id @default(uuid())
  tenantId               String                       @unique
  planId                 String
  status                 SubscriptionStatus           @default(ACTIVE)
  startsAt               DateTime
  endsAt                 DateTime?
  trialEndsAt            DateTime?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  billingProvider        BillingProvider?
  billingExternalId      String?
  billingCustomerId      String?
  currency               String?                      @default("USD")
  tenant                 Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   Plan                         @relation(fields: [planId], references: [id])
  trainingModuleAccesses TenantTrainingModuleAccess[]
  billingInvoices        BillingInvoice[]

  @@index([planId])
}

model TenantFeatureFlag {
  id         String     @id @default(uuid())
  tenantId   String
  moduleCode ModuleCode
  enabled    Boolean    @default(true)
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleCode])
  @@index([tenantId, enabled])
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String?
  type      NotificationType @default(INFO)
  title     String
  message   String
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, userId, createdAt])
  @@index([tenantId, readAt, createdAt])
}

model BillingCustomer {
  id                 String          @id @default(uuid())
  tenantId           String          @unique
  provider           BillingProvider @default(STRIPE)
  externalCustomerId String
  email              String?
  name               String?
  metadata           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([provider, externalCustomerId])
}

model BillingInvoice {
  id                String               @id @default(uuid())
  tenantId          String
  subscriptionId    String?
  provider          BillingProvider      @default(STRIPE)
  externalInvoiceId String               @unique
  status            BillingInvoiceStatus @default(OPEN)
  amount            Decimal              @db.Decimal(10, 2)
  currency          String               @default("USD")
  hostedInvoiceUrl  String?
  invoicePdfUrl     String?
  issuedAt          DateTime             @default(now())
  dueAt             DateTime?
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription      Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, issuedAt])
  @@index([tenantId, status, issuedAt])
  @@index([subscriptionId, issuedAt])
}

model UserSession {
  id               String    @id @default(uuid())
  tenantId         String
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  lastUsedAt       DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
  @@index([userId, revokedAt, expiresAt])
}

model AuditLog {
  id             String       @id @default(uuid())
  tenantId       String?
  actorTenantId  String?
  targetTenantId String?
  branchId       String?
  userId         String?
  email          String?
  actorRole      String?
  actorScope     AccessScope?
  domain         AuditDomain?
  entityType     String?
  entityId       String?
  before         Json?
  after          Json?
  correlationId  String?
  route          String
  method         String
  statusCode     Int
  ip             String?
  userAgent      String?
  action         String?
  createdAt      DateTime     @default(now())
  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([actorTenantId, createdAt])
  @@index([targetTenantId, createdAt])
  @@index([branchId, createdAt])
  @@index([tenantId, branchId, createdAt])
  @@index([userId, createdAt])
  @@index([actorRole, createdAt])
  @@index([actorScope, createdAt])
  @@index([domain, createdAt])
  @@index([email, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([correlationId, createdAt])
  @@index([route, method, createdAt])
  @@map("audit_logs")
}

model MasterWorkflow {
  id                          String                       @id @default(uuid())
  tenantId                    String
  branchId                    String
  employeeId                  String?
  candidateId                 String?
  workflowType                WorkflowType
  status                      WorkflowStatus               @default(PENDING)
  progressPercent             Int                          @default(0)
  currentStage                WorkflowStepType?
  currentStageKey             WorkflowStageKey?
  blockersSnapshot            Json?
  ownerSummary                Json?
  slaStatus                   WorkflowMasterSlaStatus      @default(ON_TIME)
  targetDate                  DateTime?
  lastEventAt                 DateTime?
  startedAt                   DateTime                     @default(now())
  completedAt                 DateTime?
  triggeredByUserId           String
  sourceModule                WorkflowSourceModule
  metadata                    Json?
  lastComputedAt              DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                      Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee                    Employee?                    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  candidate                   Candidate?                   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  triggeredByUser             User                         @relation("WorkflowTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: Restrict)
  steps                       WorkflowStep[]
  hiringFlow                  HiringFlow?
  onboardingFlow              OnboardingFlow?
  signaturePackages           SignaturePackage[]
  inventoryAssignments        InventoryAssignment[]
  inventoryRecoveries         InventoryRecovery[]
  workflowTrainingAssignments WorkflowTrainingAssignment[]
  accessTasks                 AccessTask[]
  productivityReviews         ProductivityReview[]
  operationalEvents           OperationalEvent[]
  onboardingTasks             OnboardingTask[]
  blockers                    WorkflowBlocker[]
  automationExecutions        AutomationExecution[]
  automationAuditLogs         AutomationAuditLog[]
  policyChecks                PolicyCheck[]
  assetAssignments            AssetAssignment[]
  trainingActivations         TrainingActivation[]

  @@index([tenantId, branchId])
  @@index([tenantId, workflowType, status])
  @@index([tenantId, employeeId])
  @@index([tenantId, candidateId])
  @@index([tenantId, currentStageKey])
  @@index([tenantId, branchId, slaStatus])
}

model WorkflowStep {
  id              String             @id @default(uuid())
  tenantId        String
  branchId        String
  workflowId      String
  stageKey        WorkflowStageKey?
  stepType        WorkflowStepType
  title           String?
  detail          String?
  status          WorkflowTaskStatus @default(PENDING)
  progressPercent Int                @default(0)
  ownerType       WorkflowOwnerType  @default(SYSTEM)
  ownerId         String?
  ownerLabel      String?
  slaLabel        String?
  dueDate         DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  riskStatus      WorkflowRiskStatus @default(ON_TIME)
  blockingReason  String?
  metadata        Json?
  isCritical      Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  workflow        MasterWorkflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stageKey])
  @@index([tenantId, branchId, status])
  @@index([workflowId, stepType])
  @@index([workflowId, stageKey])
  @@index([tenantId, riskStatus, dueDate])
}

model HiringFlow {
  id            String              @id @default(uuid())
  tenantId      String
  branchId      String
  workflowId    String              @unique
  candidateId   String
  employeeId    String?
  applicationId String?
  status        WorkflowTaskStatus  @default(PENDING)
  hiredAt       DateTime?
  metadata      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  workflow      MasterWorkflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  candidate     Candidate           @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  employee      Employee?           @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  application   VacancyApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, status])
  @@index([candidateId])
  @@index([employeeId])
}

model OnboardingFlow {
  id              String             @id @default(uuid())
  tenantId        String
  branchId        String
  workflowId      String             @unique
  employeeId      String
  candidateId     String?
  status          WorkflowTaskStatus @default(PENDING)
  readinessStatus String?
  startedAt       DateTime           @default(now())
  completedAt     DateTime?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
