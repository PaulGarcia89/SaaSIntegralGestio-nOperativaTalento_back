  BRANCH_ADMIN
  BRANCH_USER
}

enum AccessScope {
  GLOBAL
  TENANT
  BRANCH
}

enum AuditDomain {
  GOVERNANCE_GLOBAL
  TENANT_OPERATIONS
}

enum SubscriptionStatus {
