  RULE
  SUBSCRIPTION
  ONBOARDING
}

enum TrainingProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum TrainingEventModality {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum TrainingEventAttendanceStatus {
  INVITED
  REGISTERED
  ATTENDED
  MISSED
  CANCELLED
}

enum TrainingQuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  TEXT
}

enum TrainingQuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum TrainingFavoriteEntityType {
  COURSE
  CURRICULUM
  RESOURCE
}

enum WorkflowType {
  HIRING
  BRANCH_TRANSFER
  OFFBOARDING
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum WorkflowStageKey {
  CANDIDACY
  HIRING
  ONBOARDING
  TRAINING
  OPERATION
  ADMIN_COMPLIANCE
}

enum WorkflowStepType {
  CANDIDACY
  HIRING
  ONBOARDING
  DOCUMENTS
  SIGNATURES
  ASSET_ASSIGNMENT
  TRAINING
  TRAINING_ACTIVATION
  OPERATION
  ACCESS_PROVISIONING
  ADMIN_COMPLIANCE
  PRODUCTIVITY_REVIEW
  ASSET_RECOVERY
  ACCESS_CLOSURE
  ARCHIVE_RECORD
}

enum WorkflowOwnerType {
  SYSTEM
  USER
  EMPLOYEE
  CANDIDATE
  BRANCH
  INVENTORY
  TRAINING
  ACCESS
  SIGNATURE
  ONBOARDING
  PRODUCTIVITY
}

enum WorkflowSourceModule {
  ATS
  ONBOARDING
  INVENTORY
  TRAINING
  PRODUCTIVITY
  ADMIN
  HR
}

enum WorkflowTaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum WorkflowRiskStatus {
  ON_TIME
  AT_RISK
  OVERDUE
