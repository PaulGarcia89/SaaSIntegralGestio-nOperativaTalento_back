  MANUAL
}

enum BillingInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum TrainingDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum TrainingCourseType {
  COURSE
  VIDEO
  DOCUMENT
  QUIZ
  SCORM
  LIVE_SESSION
