  ASSIGNED
  CANCELLED
}

enum TrainingActivationStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OnboardingTaskType {
  DOCUMENT_COLLECTION
  POLICY_REVIEW
  MANAGER_CHECKLIST
  HR_CHECKLIST
  DAY_ONE_READINESS
}

enum SignaturePackageStatus {
  DRAFT
  PENDING
  PARTIALLY_SIGNED
  COMPLETED
  CANCELLED
}

enum SignatureParticipantStatus {
  PENDING
  SIGNED
  REJECTED
}

enum InventoryAssignmentStatus {
  PENDING
  ASSIGNED
  CANCELLED
}

enum InventoryRecoveryStatus {
  PENDING
  IN_PROGRESS
  RECOVERED
  CANCELLED
}

enum AccessTaskType {
  PROVISION
  UPDATE
  CLOSE
}

enum AccessTaskStatus {
  PENDING
